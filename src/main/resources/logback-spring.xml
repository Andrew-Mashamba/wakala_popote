        <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="com.quickcash.controller.CashRequestV1Controller" level="INFO" additivity="false">
        <appender-ref ref="CASH_REQUEST_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="com.quickcash.notification" level="INFO" additivity="false">
