    <!-- Loggers: one per service/feature, additivity=false so only that file gets it (and root for console if we add to root) -->
    <logger name="com.quickcash.service.AgentService" level="INFO" additivity="false">
        <appender-ref ref="AGENT_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="com.quickcash.controller.AgentController" level="INFO" additivity="false">
        <appender-ref ref="AGENT_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="com.quickcash.bolt" level="INFO" additivity="false">
        <appender-ref ref="BOLT_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="com.quickcash.service.BoltWebhookService" level="INFO" additivity="false">
        <appender-ref ref="BOLT_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>
    <logger name="com.quickcash.controller.BoltWebhookController" level="INFO" additivity="false">
        <appender-ref ref="BOLT_FILE"/>
        <appender-ref ref="CONSOLE"/>
